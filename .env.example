# Tokens do DatoCMS (Mantenha o .env.local seguro e não o versione!)
# Para o frontend ler a chave (somente leitura), o prefixo NEXT_PUBLIC_ é obrigatório no Next.js
NEXT_PUBLIC_DATOCMS_READ_ONLY_TOKEN=seu_token_de_leitura_aqui

# Para as API routes (server-side), onde podemos usar um token Full Access (leitura e escrita)
DATOCMS_FULL_ACCESS_TOKEN=seu_token_full_access_aqui
